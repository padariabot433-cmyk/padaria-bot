# String de conexão do MongoDB Atlas (ou outro MongoDB)
MONGODB_URI=mongodb+srv://santossasuke94_db_user:6KEqJi0iLh5O3dQf@cluster0.bv3ycgm.mongodb.net/padaria-bot?appName=Cluster0

# Porta que o servidor Express vai usar (Render define isso sozinho, pode deixar)
PORT=3000

# Número do WhatsApp do seu pai (dono do bot), para receber alertas de novo pedido
# Formato: código do país + DDD + número, SEM espaços, símbolos ou o "+"
# Exemplo Brasil: 5565999999999
ADMIN_NUMBER=5565984047054

# Senha para acessar o painel de pedidos em /pedidos (escolha uma senha sua)
ADMIN_PASSWORD=123456

# Números que recebem a mensagem das 8h perguntando se vão pedir hoje
# Formato: DDI+DDD+número, separados por vírgula, sem espaços
CUSTOMER_NUMBERS=5565999999999,5565988888888
# Domínio onde o painel (site/index.html) está hospedado — usado no CORS
SITE_ORIGIN=https://padariabot433-cmyk.github.io

# Ativa logs de diagnóstico (mensagens recebidas, JID @lid, etc). Deixe "false" em produção.
DEBUG_LOGS=false
